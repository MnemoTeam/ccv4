{
  "name": "@mnemoteam/types",
  "version": "0.1.0",
  "type": "module",
  "description": "TypeScript type definitions for Character Card specifications V1-V4",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "generate:types": "tsx scripts/generate.ts"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
